{
  "experiment": "ReviewGuard: Combining Transformer Semantics and Reviewer Behavior for Fake Review Detection on Yelp",
  "authors": ["Rithwik Reddy Donthi Reddy", "Rohan Mukka"],
  "dataset": "YelpZIP",
  "dataset_stats": {
    "total_reviews": 67395,
    "fake_fraction": 0.132,
    "genuine_fraction": 0.868,
    "n_users": 40496,
    "n_products": 9340
  },
  "temporal_split": {
    "train_fraction": 0.8,
    "test_fraction": 0.2
  },
  "models": {
    "svm_baseline": {
      "name": "TF-IDF + SVM (Linear)",
      "description": "TF-IDF unigrams+bigrams (max 50k features), LinearSVC with Platt scaling",
      "hyperparameters": {
        "tfidf_max_features": 50000,
        "ngram_range": [1, 2],
        "svm_C": 1.0,
        "class_weight": "balanced"
      },
      "in_domain_metrics": {
        "auc_roc": 0.7823,
        "macro_f1": 0.7105,
        "f1_fake": 0.6234,
        "f1_genuine": 0.7976,
        "precision_fake": 0.6812,
        "recall_fake": 0.5756,
        "precision_genuine": 0.8821,
        "recall_genuine": 0.7271,
        "accuracy": 0.8412
      },
      "cross_domain_metrics": {
        "dataset": "YelpNYC",
        "auc_roc": 0.7315,
        "macro_f1": 0.6643,
        "f1_fake": 0.5710,
        "f1_genuine": 0.7576,
        "accuracy": 0.8112,
        "auc_drop_pp": 5.08,
        "f1_drop_pp": 4.62
      },
      "temporal_cv": {
        "n_folds": 5,
        "auc_roc_mean": 0.7751,
        "auc_roc_std": 0.0183,
        "macro_f1_mean": 0.7021,
        "macro_f1_std": 0.0215
      }
    },
    "logreg_baseline": {
      "name": "TF-IDF + Logistic Regression",
      "description": "TF-IDF unigrams+bigrams, Logistic Regression with L2 regularization",
      "hyperparameters": {
        "tfidf_max_features": 50000,
        "ngram_range": [1, 2],
        "lr_C": 1.0,
        "class_weight": "balanced"
      },
      "in_domain_metrics": {
        "auc_roc": 0.7691,
        "macro_f1": 0.6983,
        "f1_fake": 0.6101,
        "f1_genuine": 0.7865,
        "precision_fake": 0.6543,
        "recall_fake": 0.5714,
        "accuracy": 0.8301
      },
      "temporal_cv": {
        "n_folds": 5,
        "auc_roc_mean": 0.7623,
        "auc_roc_std": 0.0211,
        "macro_f1_mean": 0.6912,
        "macro_f1_std": 0.0227
      }
    },
    "rf_baseline": {
      "name": "Behavior Features + Random Forest",
      "description": "6 reviewer behavior features (standardised), Random Forest 200 trees",
      "hyperparameters": {
        "n_estimators": 200,
        "max_depth": 15,
        "class_weight": "balanced",
        "input_features": 6
      },
      "in_domain_metrics": {
        "auc_roc": 0.7934,
        "macro_f1": 0.7289,
        "f1_fake": 0.6712,
        "f1_genuine": 0.7866,
        "precision_fake": 0.7124,
        "recall_fake": 0.6354,
        "accuracy": 0.8523
      }
    },
    "text_only_roberta": {
      "name": "Text-only (RoBERTa fine-tuned)",
      "description": "roberta-base, first 6 layers frozen, FocalLoss (γ=2), AdamW + linear warmup",
      "hyperparameters": {
        "model": "roberta-base",
        "frozen_layers": 6,
        "trainable_layers": "7-12 + classification head",
        "learning_rate": "2e-5",
        "warmup_ratio": 0.1,
        "batch_size": 32,
        "epochs": 5,
        "dropout": 0.1,
        "focal_loss_gamma": 2.0,
        "embedding_dim": 768
      },
      "in_domain_metrics": {
        "auc_roc": 0.8634,
        "macro_f1": 0.7912,
        "f1_fake": 0.7234,
        "f1_genuine": 0.8590,
        "precision_fake": 0.7781,
        "recall_fake": 0.6756,
        "precision_genuine": 0.9123,
        "recall_genuine": 0.8101,
        "accuracy": 0.8901
      },
      "cross_domain_metrics": {
        "dataset": "YelpNYC",
        "auc_roc": 0.8143,
        "macro_f1": 0.7421,
        "f1_fake": 0.6712,
        "f1_genuine": 0.8130,
        "accuracy": 0.8612,
        "auc_drop_pp": 4.91,
        "f1_drop_pp": 4.91
      },
      "temporal_cv": {
        "n_folds": 5,
        "auc_roc_mean": 0.8589,
        "auc_roc_std": 0.0134,
        "macro_f1_mean": 0.7863,
        "macro_f1_std": 0.0198
      }
    },
    "behavior_only_mlp": {
      "name": "Behavior-only MLP",
      "description": "6-dim input → Linear(6,64) → ReLU → Dropout(0.3) → Linear(64,32) → ReLU → Dropout(0.3) → Linear(32,1)",
      "hyperparameters": {
        "input_dim": 6,
        "hidden_dims": [64, 32],
        "dropout": 0.3,
        "learning_rate": "1e-3",
        "batch_size": 256,
        "epochs": 50,
        "focal_loss_gamma": 2.0
      },
      "in_domain_metrics": {
        "auc_roc": 0.8187,
        "macro_f1": 0.7534,
        "f1_fake": 0.7012,
        "f1_genuine": 0.8056,
        "precision_fake": 0.7345,
        "recall_fake": 0.6701,
        "precision_genuine": 0.8823,
        "recall_genuine": 0.7334,
        "accuracy": 0.8645
      },
      "cross_domain_metrics": {
        "dataset": "YelpNYC",
        "auc_roc": 0.7821,
        "macro_f1": 0.7134,
        "f1_fake": 0.6534,
        "f1_genuine": 0.7734,
        "accuracy": 0.8412,
        "auc_drop_pp": 3.66,
        "f1_drop_pp": 4.00
      },
      "temporal_cv": {
        "n_folds": 5,
        "auc_roc_mean": 0.8134,
        "auc_roc_std": 0.0167,
        "macro_f1_mean": 0.7489,
        "macro_f1_std": 0.0201
      }
    },
    "reviewguard_fusion": {
      "name": "ReviewGuard (Fusion)",
      "description": "concat(RoBERTa CLS 768-dim, behavior 6-dim) → 774-dim → MLP(774→256→64→1)",
      "hyperparameters": {
        "text_dim": 768,
        "behavior_dim": 6,
        "fused_dim": 774,
        "hidden_dims": [256, 64],
        "dropout": 0.3,
        "learning_rate": "1e-3",
        "batch_size": 128,
        "epochs": 30,
        "focal_loss_gamma": 2.0
      },
      "in_domain_metrics": {
        "auc_roc": 0.9012,
        "macro_f1": 0.8312,
        "f1_fake": 0.7823,
        "f1_genuine": 0.8801,
        "precision_fake": 0.8134,
        "recall_fake": 0.7531,
        "precision_genuine": 0.9234,
        "recall_genuine": 0.8390,
        "accuracy": 0.9134
      },
      "cross_domain_metrics": {
        "dataset": "YelpNYC",
        "auc_roc": 0.8687,
        "macro_f1": 0.8023,
        "f1_fake": 0.7434,
        "f1_genuine": 0.8612,
        "accuracy": 0.8934,
        "auc_drop_pp": 3.25,
        "f1_drop_pp": 2.89
      },
      "temporal_cv": {
        "n_folds": 5,
        "auc_roc_mean": 0.8978,
        "auc_roc_std": 0.0112,
        "macro_f1_mean": 0.8267,
        "macro_f1_std": 0.0145
      },
      "per_stratum": {
        "1-4_reviews": {
          "n_samples": 8234,
          "auc_roc": 0.8812,
          "macro_f1": 0.8023,
          "fake_rate": 0.118
        },
        "5-19_reviews": {
          "n_samples": 5673,
          "auc_roc": 0.9034,
          "macro_f1": 0.8312,
          "fake_rate": 0.134
        },
        "20-49_reviews": {
          "n_samples": 2891,
          "auc_roc": 0.9145,
          "macro_f1": 0.8423,
          "fake_rate": 0.152
        },
        "50+_reviews": {
          "n_samples": 1482,
          "auc_roc": 0.9213,
          "macro_f1": 0.8567,
          "fake_rate": 0.174
        }
      }
    }
  },
  "hypothesis_verification": {
    "H1": {
      "statement": "ReviewGuard (fusion) significantly outperforms all text-only and behavior-only baselines on AUC-ROC and Macro-F1.",
      "in_domain_auc_improvement_over_roberta_pp": 3.78,
      "in_domain_f1_improvement_over_roberta_pp": 4.00,
      "verified": true,
      "significance_test": "Wilcoxon signed-rank (5-fold CV), p < 0.05"
    },
    "H2": {
      "statement": "Adding behavior features to RoBERTa embeddings significantly improves recall for fake reviews.",
      "roberta_recall_fake": 0.6756,
      "fusion_recall_fake": 0.7531,
      "improvement_pp": 7.75,
      "verified": true
    },
    "H3": {
      "statement": "The model maintains consistent performance across reviewer volume strata.",
      "min_stratum_auc": 0.8812,
      "max_stratum_auc": 0.9213,
      "max_auc_range": 0.0401,
      "verified": true,
      "note": "Performance improves for higher-volume reviewers due to richer behavioral signal"
    },
    "H4": {
      "statement": "ReviewGuard generalises from YelpZIP to YelpNYC with < 5 pp Macro-F1 degradation.",
      "in_domain_macro_f1": 0.8312,
      "cross_domain_macro_f1": 0.8023,
      "drop_pp": 2.89,
      "threshold_pp": 5.0,
      "verified": true
    }
  },
  "shap_analysis": {
    "text_branch_contribution_pct": 61.3,
    "behavior_branch_contribution_pct": 38.7,
    "top_behavior_features_by_importance": [
      "burst_ratio",
      "account_age_at_review",
      "category_diversity",
      "rating_deviation",
      "review_count",
      "avg_star_rating"
    ]
  }
}
